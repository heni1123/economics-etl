{
  "sources": [
    {
      "name": "worldbank_gdp",
      "url": "https://api.worldbank.org/v2/country/all/indicator/NY.GDP.MKTP.CD",
      "auth": "none"
    },
    {
      "name": "worldbank_population",
      "url": "https://api.worldbank.org/v2/country/all/indicator/SP.POP.TOTL",
      "auth": "none"
    },
    {
      "name": "exchangerate_api",
      "url": "https://open.er-api.com/v6/latest/USD",
      "auth": "none"
    },
    {
      "name": "restcountries_info",
      "url": "https://restcountries.com/v3.1/all",
      "auth": "none"
    }
  ],
  "targets": [
    {
      "table": "fact_economic_indicators",
      "schema": "public",
      "load_strategy": "upsert"
    },
    {
      "table": "fact_exchange_rates",
      "schema": "public",
      "load_strategy": "truncate_insert"
    },
    {
      "table": "dim_country",
      "schema": "public",
      "load_strategy": "upsert"
    }
  ],
  "pipeline_settings": {
    "idempotency": true,
    "error_handling": {
      "retry_policy": {
        "max_retries": 3,
        "backoff_factor": 2,
        "initial_delay": 1
      }
    },
    "logging": {
      "log_level": "INFO",
      "log_path": "/var/log/etl_pipeline.log"
    }
  },
  "retry_policies": {
    "default": {
      "max_attempts": 3,
      "delay": 2
    }
  },
  "monitoring": {
    "enabled": true,
    "metrics": {
      "extraction": true,
      "loading": true,
      "performance": true
    },
    "alerting": {
      "enabled": true,
      "thresholds": {
        "error_rate": 0.1,
        "execution_time": 300
      }
    }
  },
  "schedule": {
    "frequency": "daily",
    "time": "00:00 UTC"
  }
}